{
  "name": "pige",
  "version": "0.3.0",
  "description": "Terminal calendar for freelance day tracking on top of Solidtime",
  "license": "MIT",
  "author": "Rashad Karanouh <11599358+rashad@users.noreply.github.com>",
  "homepage": "https://github.com/rashad/pige#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rashad/pige.git"
  },
  "bugs": {
    "url": "https://github.com/rashad/pige/issues"
  },
  "keywords": [
    "freelance",
    "solidtime",
    "cli",
    "calendar",
    "time-tracking",
    "tjm",
    "terminal"
  ],
  "type": "module",
  "bin": {
    "pige": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --target node20 --clean --shims",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "prepare": "npm run build",
    "link:local": "npm run build && npm link"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@napi-rs/keyring": "^1.3.0",
    "chalk": "^5.3.0",
    "date-holidays": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.7.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
